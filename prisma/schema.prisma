generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  MOZO
  CAJERO
}

enum EstadoMesa {
  LIBRE
  OCUPADA
  RESERVADA
}

enum EstadoComanda {
  ABIERTA
  LISTA_PARA_COBRAR
  CERRADA
  CANCELADA
}

enum EstadoPedido {
  PENDIENTE
  EN_PREPARACION
  LISTO
  ENTREGADO
  CANCELADO
}

enum CategoriaArticulo {
  COMIDA
  BEBIDA
  POSTRE
  ENTRADA
  OTRO
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
  QR
  PEDIDOS_YA_CTA_CTE
  PEDIDOS_YA_EFECTIVO
  RAPPI_CTA_CTE
  RAPPI_EFECTIVO
}

// ─── MODELOS ─────────────────────────────────────────────

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(MOZO)
  createdAt DateTime  @default(now())
  comandas  Comanda[] @relation("MozoComandas")
  arqueos   Arqueo[]
}

model Sector {
  id     Int    @id @default(autoincrement())
  nombre String @unique
  mesas  Mesa[]
}

model Mesa {
  id        Int        @id @default(autoincrement())
  numero    Int        @unique
  capacidad Int
  estado    EstadoMesa @default(LIBRE)
  sectorId  Int
  sector    Sector     @relation(fields: [sectorId], references: [id])
  comandas  Comanda[]
}

model Articulo {
  id         Int               @id @default(autoincrement())
  nombre     String
  precio     Float
  categoria  CategoriaArticulo
  disponible Boolean           @default(true)
  pedidos    Pedido[]
}

model Comanda {
  id         Int           @id @default(autoincrement())
  mesaId     Int
  mozoId     Int
  estado     EstadoComanda @default(ABIERTA)
  total      Float         @default(0)
  comensales Int           @default(1)
  createdAt  DateTime      @default(now())
  closedAt   DateTime?
  mesa       Mesa          @relation(fields: [mesaId], references: [id])
  mozo       User          @relation("MozoComandas", fields: [mozoId], references: [id])
  pedidos    Pedido[]
  cobro      Cobro?
}

model Pedido {
  id         Int          @id @default(autoincrement())
  comandaId  Int
  articuloId Int
  cantidad   Int
  precio     Float
  estado     EstadoPedido @default(PENDIENTE)
  nota       String?
  createdAt  DateTime     @default(now())
  comanda    Comanda      @relation(fields: [comandaId], references: [id])
  articulo   Articulo     @relation(fields: [articuloId], references: [id])
}

// Registro del pago al cerrar una comanda
model Cobro {
  id           Int        @id @default(autoincrement())
  comandaId    Int        @unique
  metodoPago   MetodoPago
  montoAbonado Float
  vuelto       Float      @default(0)
  observaciones String?
  fecha        DateTime   @default(now())
  comanda      Comanda    @relation(fields: [comandaId], references: [id])
}

model Arqueo {
  id            Int      @id @default(autoincrement())
  cajeroId      Int
  fecha         DateTime @default(now())

  // Conteo de billetes en efectivo
  billetes1000  Int      @default(0)
  billetes2000  Int      @default(0)
  billetes5000  Int      @default(0)
  billetes10000 Int      @default(0)
  billetes20000 Int      @default(0)
  billetes50000 Int      @default(0)

  // Totales por método de pago
  totalEfectivo          Float @default(0)
  totalDebito            Float @default(0)
  totalCredito           Float @default(0)
  totalTransferencia     Float @default(0)
  totalQr                Float @default(0)
  totalPedidosYaCtaCte   Float @default(0)
  totalPedidosYaEfectivo Float @default(0)
  totalRappiCtaCte       Float @default(0)
  totalRappiEfectivo     Float @default(0)

  // Cierre
  totalGeneral  Float
  diferencia    Float    @default(0)
  observaciones String?

  cajero        User     @relation(fields: [cajeroId], references: [id])
}

